# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Fine-tuned Model (optional - only if you have a fine-tuned OpenAI model that you want to use for mentor selection instead of gpt-4o-mini)
OPENAI_FINETUNED_MODEL=ft:gpt-4o-mini:your-model-id

# Helicone API Key
HELICONE_API_KEY=your_helicone_api_key_here

# Qdrant Configuration
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Cohere API Key
COHERE_API_KEY=your_cohere_api_key_here

